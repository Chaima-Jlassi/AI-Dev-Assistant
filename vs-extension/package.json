{
  "name": "ai-dev-assistant",
  "displayName": "AI Dev Assistant",
  
  "description": "Your AI-powered coding assistant",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiDevAssistant.openPanel",
        "title": "Open AI Dev Assistant"
      },
      {
        "command": "aiDevAssistant.explainSelection",
        "title": "AI Dev Assistant: Explain Selected Code"
      }
    ],
    "keybindings": [
      {
        "command": "aiDevAssistant.openPanel",
        "key": "ctrl+shift+a",
        "when": "editorTextFocus"
      },
      {
        "command": "aiDevAssistant.explainSelection",
        "key": "ctrl+alt+e",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "configuration": {
      "title": "AI Dev Assistant",
      "properties": {
        "aiDevAssistant.backendUrl": {
          "type": "string",
          "default": "http://localhost:18000",
          "description": "Base URL for the backend API used by the extension."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiDevAssistant",
          "title": "AI Dev Assistant"
        }
      ]
    },
    "views": {
      "aiDevAssistant": [
        {
          "type": "webview",
          "id": "aiDevAssistant.panel",
          "name": "AI Dev Assistant"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
  "@types/node": "^20.0.0",
  "@types/vscode": "^1.85.0",
  "typescript": "~5.4.5"
}
}
