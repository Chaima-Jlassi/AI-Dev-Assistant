OLLAMA_URL=http://host.docker.internal:11434/api/generate
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=180
OLLAMA_MAX_RETRIES=3
OLLAMA_TEMPERATURE=0.3
PLANTUML_URL=http://www.plantuml.com/plantuml/png/
PLANTUML_TIMEOUT=30
PLANTUML_OUTPUT_DIR=./outputs/diagrams
PLANTUML_LOCAL=false
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_TOP_K=2
RAG_MIN_SIMILARITY=0.3
OUTPUT_DIAGRAMS_DIR=./outputs/diagrams
OUTPUT_README_DIR=./outputs/readme
OUTPUT_TESTS_DIR=./outputs/tests
OUTPUT_EXPLANATIONS_DIR=./outputs/explanations
DEBUG=false
LOG_LEVEL=INFO
LOG_FILE=
